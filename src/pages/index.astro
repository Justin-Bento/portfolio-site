---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";
const blogs = Object.values(import.meta.glob("./blogs/*.md", { eager: true }));
const { frontmatter } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Justin Bento</title>
  </head>
  <body>
    <Header />
    <main class="max-w-7xl mx-auto px-4 py-5 sm:p-6 min-h-dvh">
      <section class="w-full flex items-center aspect-video">
        <div class="">
          <h1 class="text-5xl text-zinc-950 font-bold leading-[1.125]">
            Hi, my name is Justin Bento. <br />
            I am a Full-Stack Developer.
          </h1>
          <p class="text-zinc-950 text-xl/[1.5] max-w-4xl text-balance mt-4">
            I build web apps with Ruby and Rails, JavaScirpt, React.js, Astro.js
            & Tailwind CSS. Currently, I&#39;m focused on building accessible,
            human-centered products.
          </p>
          <a
            href="/projects"
            class="block w-fit mt-8 bg-zinc-950 rounded text-zinc-50 px-5 py-2 text-sm uppercase tracking-wide leading-[2] font-medium hover:bg-sky-500 transition-all"
            >View Project
          </a>
        </div>
      </section>
      <section class="py-24">
        <h2
          class="font-mono text-[2.488rem]/[2] font-extrabold space-x-4 flex items-center gap-4"
        >
          <span class=""><sup class="mr-2 text-sky-500">#1.</sup>About Me</span>
        </h2>
        <div
          class="[&>p]:leading-[2] max-w-[100ch] text-pretty tracking-wide space-y-6"
        >
          <p>
            Hello! My name is Justin, and I enjoy creating things that live on
            the internet. My interest in web development started back in 2016
            when I decided to spend time researching and learning about youtube
            banner speedart &dash; and watching Caler Edwards do speedruns with
            website design. As it turns out trying to recreate these designs and
            code by looking at templates with taught me a lot about graphic
            design alongside HTML and CSS.
          </p>
          <p>
            I enrolled in Humber College's Website Design and Development
            program, and here I learned how to build websites for a living.
            Which eventually lent me to get hired by Humber college and here I
            collaborated with content creators, graphic designers and project
            managers and built the actual Front-End for various college courses.
            After the corse was built by the lead developer we deployed it using
            Humber's internal system code so thousands of students could
            interact with the course.
          </p>
          <p>
            Fast-Foward to today I am currently looking for work. Even with me
            looking for work I am constantly training myself to find new
            patterns by learning lower level code from The Odin Project,
            building dozens of portfolio-worthy projects and playing Guitar on
            the side.
          </p>
          <p>Here are a few technologies I’ve been working with recently:</p>
          <span class="flex items-center gap-32">
            <ul class="list-disc list-inside">
              <li>HTML</li>
              <li>CSS</li>
              <li>JavaScript</li>
              <li>TypeScript</li>
              <li>React.js</li>
              <li>Node.js</li>
            </ul>
            <ul class="list-disc list-inside">
              <li>Ruby</li>
              <li>Ruby on Rails</li>
              <li>Tailwind CSS</li>
              <li>Sanity CMS</li>
              <li>Supabase</li>
              <li>Next.js</li>
            </ul>
          </span>
        </div>
      </section>
      <section class="py-24">
        <h2
          class="font-mono text-[2.488rem]/[2] font-extrabold space-x-4 flex items-center gap-2"
        >
          <span class="">
            <sup class="text-sky-500">#3.</sup>
            Some things I've Built.
          </span>
        </h2>
        <!-- Be sure to use this with a layout container that is full-width on mobile -->
        <div class="overflow-hidden border border-zinc-300">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-[1.2rem]/[1.4] font-mono up capitalize">
              Card Title
            </h3>
          </div>
        </div>
      </section>
      <section class="py-24">
        <h2
          class="font-mono text-[2.488rem]/[2] font-extrabold space-x-4 flex items-center gap-2"
        >
          <span class="">
            <sup class="text-sky-500">#4.</sup>
            Stuff I want to Share.
          </span>
        </h2>
        <ul class="grid grid-cols-1 lg:grid-cols-3 gap-12 mt-12">
          {
            blogs.map((blog) => {
              return (
                <li class="group transition-all relative isolate flex flex-col bg-white border-2 border-zinc-900 hover:border-sky-500 shadow-2xs rounded-xl overflow-hidden">
                  <img
                    class="w-full h-auto rounded-t-xl"
                    src="/image/gratisograph-mars-robot.jpg"
                    alt="Card Image"
                  />
                  <div class="p-4 md:p-5">
                    <h3 class="text-lg font-bold text-zinc-800 group-hover:text-sky-500 capitalize">
                      <a href={blog.url}>
                        {blog.frontmatter.title}
                        <span class="absolute inset-0 z-10 hover:bg-sky-50/10" />
                      </a>
                    </h3>
                    <p class="mt-1 text-zinc-500 leading-[1.5] line-clamp-3">
                      Some quick example text to build on the card title and
                      make up the bulk of the card's content. This is an
                      example.
                    </p>
                  </div>
                </li>
              );
            })
          }
        </ul>
      </section>
      <section class="py-24">
        <h2
          class="font-mono text-[2.488rem]/[2] font-extrabold space-x-4 flex items-center gap-2"
        >
          <span class="">
            <sup class="text-sky-500">#5.</sup>
            Get In Touch.
          </span>
        </h2>
        <div
          class="[&>p]:leading-[2] max-w-[100ch] text-pretty tracking-wide space-y-6"
        >
        </div>
      </section>
      <section class="py-24">
        <h2
          class="font-mono text-[2.488rem]/[2] font-extrabold space-x-4 flex items-center gap-2"
        >
          <span class="">
            <sup class="text-sky-500">#6.</sup>
            Get In Touch.
          </span>
        </h2>
        <div
          class="[&>p]:leading-[2] max-w-[100ch] text-pretty tracking-wide space-y-6"
        >
        </div>
      </section>
    </main>
  </body>
  <Footer />
</html>
