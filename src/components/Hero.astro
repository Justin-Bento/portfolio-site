---
import { marked } from 'marked';
import siteConfig from '../data/site-config';
import Button from './Button.astro';
const hero = siteConfig.hero;
---

{
    (hero?.title ||
        hero?.image?.src ||
        hero?.lightThemeImage?.src ||
        hero?.darkThemeImage?.src ||
        hero?.text ||
        (hero?.actions && hero.actions.length > 0)) && (
        <section class="w-full flex flex-col gap-8 mb-16 sm:mb-24">
            {hero.title && <h1 class="text-3xl leading-tight font-serif font-medium sm:text-5xl sm:leading-tight">{hero.title}</h1>}

            {(hero.image?.src || hero.lightThemeImage?.src || hero.darkThemeImage?.src) && (
                <figure>
                    {/* Light theme image */}
                    {hero.lightThemeImage?.src && (
                        <img
                            class="w-full block dark:hidden"
                            src={hero.lightThemeImage.src}
                            loading="lazy"
                            decoding="async"
                            alt={hero.lightThemeImage.alt || ''}
                        />
                    )}

                    {/* Dark theme image */}
                    {hero.darkThemeImage?.src && (
                        <img
                            class="w-full hidden dark:block"
                            src={hero.darkThemeImage.src}
                            loading="lazy"
                            decoding="async"
                            alt={hero.darkThemeImage.alt || ''}
                        />
                    )}

                    {/* Fallback to default image if no theme-specific images */}
                    {!hero.lightThemeImage?.src && !hero.darkThemeImage?.src && hero.image?.src && (
                        <img class="w-full" src={hero.image.src} loading="lazy" decoding="async" alt={hero.image.alt || ''} />
                    )}

                    {/* Caption from any available image */}
                    {(hero.image?.caption || hero.lightThemeImage?.caption || hero.darkThemeImage?.caption) && (
                        <figcaption class="mt-1.5 text-xs sm:text-sm">
                            {hero.lightThemeImage?.caption || hero.darkThemeImage?.caption || hero.image?.caption}
                        </figcaption>
                    )}
                </figure>
            )}

            {hero.text && <div class="max-w-none prose sm:prose-lg" set:html={marked.parse(hero.text)} />}
            {hero.actions && hero.actions.length > 0 && (
                <div class="flex flex-wrap gap-4">
                    {hero.actions.map((action) => (
                        <Button href={action.href}>{action.text}</Button>
                    ))}
                </div>
            )}
        </section>
    )
}
