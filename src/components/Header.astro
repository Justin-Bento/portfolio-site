---
const navigation = ["home", "projects", "blogs"];
---

<header
  class="sticky top-0 z-50 bg-white dark:bg-gray-900 transition-shadow duration-300"
>
  <div class="max-w-[100ch] mx-auto p-6 flex items-center justify-between">
    <ul class="gap-2 flex items-center">
      {
        navigation.map((item, index) => {
          return (
            <li class="relative isolate">
              <a
                href={item === "home" ? "/" : `/${item.toLowerCase()}`}
                class="text-base/[2] p-2 font-serif capitalize hover:underline"
              >
                {index}.&nbsp;{item}
                <span class="absolute inset-0" />
              </a>
            </li>
          );
        })
      }
    </ul>
    <div class="">
      <a
        href="https://github.com/Justin-Bento"
        class="font-serif after:content-['_↗'] hover:underlinetext-base/[2] p-2 capitalize hover:underline"
        >Github</a
      >
    </div>
  </div>
</header>

<script is:inline>
  {
    const initHeaderShadow = () => {
      const header = document.querySelector("header");
      if (!header) return;

      const sentinel = document.createElement("div");
      sentinel.style.position = "absolute";
      sentinel.style.top = "0";
      sentinel.style.height = "1px";
      document.body.prepend(sentinel);

      const observer = new IntersectionObserver(
        ([entry]) => {
          header.classList.toggle("shadow-md", !entry.isIntersecting);
        },
        { threshold: 0.1 }
      );

      observer.observe(sentinel);

      // Cleanup when navigating away (important for SPA behavior)
      const cleanup = () => {
        observer.disconnect();
        sentinel.remove();
        window.removeEventListener("beforeunload", cleanup);
      };
      window.addEventListener("beforeunload", cleanup);
    };

    if (document.readyState === "complete") {
      initHeaderShadow();
    } else {
      document.addEventListener("DOMContentLoaded", initHeaderShadow);
    }
  }
</script>
